.git
.venv
.pytest_cache
__pycache__
*.pyc

# Dev tools
references/
reports/

# Notebooks and raw data are not needed at runtime
src/notebooks/
src/data/

# Tests don't run inside the container
src/tests/

# Pickled sklearn artifacts: only the build-time export step reads them; the
# runtime image serves from the exported model_lite.npz/json instead.
src/models/*.pkl
.venv-parity/
